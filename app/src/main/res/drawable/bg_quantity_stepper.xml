<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/mypage_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/white_alt" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/mypage_fennel" />
            <stroke
                android:width="1dp"
                android:color="@color/mypage_fern" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/mypage_warm_white" />
            <stroke
                android:width="1dp"
                android:color="@color/mypage_fern" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
