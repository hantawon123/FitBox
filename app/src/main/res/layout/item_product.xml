<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="184dp"
    android:layout_height="252dp"
    android:layout_marginEnd="14dp"
    app:cardBackgroundColor="@color/mypage_warm_white"
    app:cardCornerRadius="6dp"
    app:cardElevation="3dp"
    app:cardUseCompatPadding="true"
    app:strokeColor="@android:color/transparent"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivProductImage"
            android:layout_width="match_parent"
            android:layout_height="152dp"
            android:background="@android:color/white"
            android:contentDescription="상품 이미지"
            android:scaleType="centerCrop"
            android:src="@drawable/logo_full_background_remove" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_product_text_panel"
            android:orientation="vertical"
            android:paddingStart="@dimen/fit_space_md"
            android:paddingTop="6dp"
            android:paddingEnd="@dimen/fit_space_sm"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/tvProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="닭가슴살 현미 도시락"
                android:textColor="@color/mypage_text"
                android:textSize="13sp"
                android:textStyle="normal" />

            <TextView
                android:id="@+id/tvProductNutrition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="520kcal · 탄수화물 45g · 단백질 35g · 지방 12g"
                android:textColor="@color/mypage_text_secondary"
                android:textSize="11sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvProductPrice"
                style="@style/FitText.PrimaryDarkBold15"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="7,900원"
                android:textColor="@color/mypage_fern" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
