<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mypage_background">

    <LinearLayout
        android:id="@+id/layoutAdminHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/fit_space_xl"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/FitText.PrimaryBold24"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="매장 주문 관리" />

                <TextView
                    android:id="@+id/tvAdminName"
                    style="@style/FitText.Secondary13"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fit_space_xs"
                    android:text="관리자님, 주문을 확인해주세요." />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/layoutAdminNotificationButton"
                android:layout_width="44dp"
                android:layout_height="44dp">

                <ImageButton
                    android:id="@+id/btnAdminNotifications"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="관리자 알림 확인"
                    android:padding="@dimen/fit_space_sm"
                    android:src="@drawable/notifications"
                    app:tint="@color/mypage_fern" />

                <TextView
                    android:id="@+id/tvAdminNotificationCountBadge"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/bg_cart_count_badge"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminLogout"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="로그아웃"
                android:textColor="@color/mypage_fern" />
        </LinearLayout>

        <TextView
            style="@style/FitText.Secondary12"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_md"
            android:text="주문 접수·준비 완료·픽업 안내 시 해당 고객에게 Firebase 푸시 알림을 발송합니다." />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="@dimen/fit_space_lg">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleOrderStatus"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_gravity="bottom"
                app:checkedButton="@id/btnWaitingOrders"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWaitingOrders"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="수락 대기" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnActiveOrders"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="진행 중" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCompletedOrders"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="픽업 완료" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:id="@+id/tvWaitingOrderCountBadge"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="top"
                android:layout_marginStart="82dp"
                android:layout_marginTop="0dp"
                android:background="@drawable/bg_cart_count_badge"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressAdminOrders"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutAdminHeader" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAdminOrders"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/fit_space_xl"
        android:paddingBottom="@dimen/fit_space_2xl"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutAdminHeader" />

    <TextView
        android:id="@+id/tvAdminOrderEmpty"
        style="@style/FitText.Secondary14"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="진행 중인 주문이 없습니다."
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/rvAdminOrders"
        app:layout_constraintEnd_toEndOf="@id/rvAdminOrders"
        app:layout_constraintStart_toStartOf="@id/rvAdminOrders"
        app:layout_constraintTop_toTopOf="@id/rvAdminOrders" />

</androidx.constraintlayout.widget.ConstraintLayout>
