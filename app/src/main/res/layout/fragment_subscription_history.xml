<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mypage_background"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/fit_space_xl"
        android:text="정기구독 내역"
        style="@style/FitText.PrimaryBold24" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnShowSubscriptionCalendar"
        style="@style/MypageSecondaryButton"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginHorizontal="@dimen/fit_space_lg"
        android:layout_marginBottom="@dimen/fit_space_sm"
        android:text="구독 확인하기"
        app:icon="@drawable/ic_calendar_line"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/fit_space_sm"
        app:iconTint="@color/mypage_fern" />

    <LinearLayout
        android:id="@+id/layoutSubscriptionEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/fit_space_2xl"
        android:visibility="gone">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:alpha="0.7"
            android:contentDescription="구독 내역 없음"
            android:src="@drawable/list"
            app:tint="@color/mypage_text_secondary" />

        <TextView
            android:id="@+id/tvSubscriptionEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_lg"
            android:gravity="center"
            android:text="현재 이용 중인 구독이 없어요"
            style="@style/FitText.PrimaryBold17" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="내 일정에 맞는 식단 구독을 만들어보세요."
            style="@style/FitText.Secondary13" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubscriptionEmptyAction"
            style="@style/MypagePrimaryButton"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:layout_marginTop="18dp"
            android:minHeight="46dp"
            android:text="구독 시작하기" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSubscriptions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
