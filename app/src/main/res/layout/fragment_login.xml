<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_my_page_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="@dimen/fit_space_md"
        android:paddingTop="@dimen/fit_space_2xl"
        android:paddingEnd="@dimen/fit_space_md"
        android:paddingBottom="@dimen/fit_space_2xl">

        <ImageView
            android:id="@+id/ivLoginLogo"
            android:layout_width="156dp"
            android:layout_height="58dp"
            android:layout_marginStart="@dimen/fit_space_sm"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            android:scaleType="fitStart"
            android:src="@drawable/logo_background_remove" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/fit_space_sm"
            android:layout_marginTop="@dimen/fit_space_xs"
            android:text="나만의 맞춤 식단을 시작해보세요"
            android:textColor="@color/mypage_text_secondary"
            android:textSize="13sp" />

        <View
            style="@style/FitDivider.Subtle"
            android:layout_marginTop="@dimen/fit_space_lg"
            android:layout_marginBottom="@dimen/fit_space_lg" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="18dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilUserId"
            style="@style/FitInputLayout"
            android:layout_width="330dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:hint="아이디"
            app:boxBackgroundColor="@color/mypage_warm_white"
            app:boxStrokeColor="@color/mypage_fern"
            app:hintTextColor="@color/mypage_text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUserId"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="text"
                android:minHeight="48dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:textColor="@color/mypage_text"
                android:textColorHint="@color/mypage_text_secondary" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/FitInputLayout"
            android:layout_width="330dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:hint="비밀번호"
            app:boxBackgroundColor="@color/mypage_warm_white"
            app:boxStrokeColor="@color/mypage_fern"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/mypage_fern"
            app:hintTextColor="@color/mypage_text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textPassword"
                android:minHeight="48dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:textColor="@color/mypage_text"
                android:textColorHint="@color/mypage_text_secondary" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="330dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/fit_space_md"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvFindId"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="아이디 찾기"
                android:textColor="@color/mypage_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDivider1"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="@dimen/fit_space_md"
                android:layout_marginEnd="@dimen/fit_space_md"
                android:gravity="center"
                android:text="|"
                android:textColor="@color/fit_surface_variant"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvFindPassword"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="비밀번호 찾기"
                android:textColor="@color/mypage_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDivider2"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="@dimen/fit_space_md"
                android:layout_marginEnd="@dimen/fit_space_md"
                android:gravity="center"
                android:text="|"
                android:textColor="@color/fit_surface_variant"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvGoRegister"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="회원가입"
                android:textColor="@color/mypage_fern"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            style="@style/FitPrimaryButton"
            android:layout_width="330dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/fit_space_lg"
            android:backgroundTint="@color/mypage_fern"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="48dp"
            android:text="로그인"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="6dp"
            app:icon="@drawable/ic_login_line"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconTint="@color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/fit_surface_variant" />

            <TextView
                android:id="@+id/tvSocialLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/fit_space_lg"
                android:layout_marginEnd="@dimen/fit_space_lg"
                android:text="또는 소셜 계정 로그인"
                android:textColor="@color/mypage_text_secondary"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/fit_surface_variant" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_lg"
            android:layout_marginBottom="@dimen/fit_space_lg"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingTop="@dimen/fit_space_xs"
            android:paddingBottom="@dimen/fit_space_sm">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/btnKakaoLogin"
                style="@style/SocialLoginButtonStyle"
                android:layout_marginEnd="@dimen/fit_space_lg"
                android:contentDescription="카카오톡 로그인"
                android:src="@drawable/kakao_talk_logo" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/btnNaverLogin"
                style="@style/SocialLoginButtonStyle"
                android:layout_marginEnd="@dimen/fit_space_lg"
                android:contentDescription="네이버 로그인"
                android:src="@drawable/naver_logo" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/btnGoogleLogin"
                style="@style/SocialLoginButtonStyle"
                android:contentDescription="구글 로그인"
                android:src="@drawable/google_logo" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
