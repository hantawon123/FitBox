<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_my_page_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/fit_space_md"
        android:paddingTop="@dimen/fit_space_lg"
        android:paddingEnd="@dimen/fit_space_md"
        android:paddingBottom="@dimen/fit_space_2xl">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="‹"
                android:textColor="@color/mypage_text"
                android:textSize="28sp" />

            <TextView
                style="@style/FitText.PrimaryBold18"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="회원 정보 수정"
                android:textColor="@color/mypage_text" />

            <Space
                android:layout_width="42dp"
                android:layout_height="42dp" />
        </LinearLayout>

                <TextView
                    style="@style/FitText.PrimaryBold16"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fit_space_xl"
                    android:text="기본 정보"
                    android:textColor="@color/mypage_text" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FitInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="이름"
                    app:boxBackgroundColor="@color/mypage_warm_white"
                    app:boxStrokeColor="@color/mypage_fern"
                    app:hintTextColor="@color/mypage_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:inputType="textPersonName"
                        android:minHeight="42dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:textColor="@color/mypage_text"
                        android:textColorHint="@color/mypage_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/FitInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="전화번호"
                    app:boxBackgroundColor="@color/mypage_warm_white"
                    app:boxStrokeColor="@color/mypage_fern"
                    app:hintTextColor="@color/mypage_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:inputType="phone"
                        android:minHeight="42dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:textColor="@color/mypage_text"
                        android:textColorHint="@color/mypage_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/FitInputLayout"
                        android:layout_width="96dp"
                        android:layout_height="wrap_content"
                        android:hint="나이"
                        app:boxBackgroundColor="@color/mypage_warm_white"
                        app:boxStrokeColor="@color/mypage_fern"
                        app:hintTextColor="@color/mypage_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAge"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:inputType="number"
                            android:minHeight="42dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            android:textColor="@color/mypage_text"
                            android:textColorHint="@color/mypage_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <RadioGroup
                        android:id="@+id/rgGender"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="@dimen/fit_space_lg"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rbMale"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/fit_space_lg"
                            android:buttonTint="@color/profile_edit_radio_tint"
                            android:text="남성"
                            android:textColor="@color/mypage_text" />

                        <RadioButton
                            android:id="@+id/rbFemale"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/profile_edit_radio_tint"
                            android:text="여성"
                            android:textColor="@color/mypage_text" />
                    </RadioGroup>
                </LinearLayout>

                <View
                    style="@style/FitDivider.Subtle"
                    android:layout_marginTop="@dimen/fit_space_lg"
                    android:layout_marginBottom="@dimen/fit_space_lg" />

                <TextView
                    style="@style/FitText.PrimaryBold16"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="식단 추천 정보"
                    android:textColor="@color/mypage_text" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/FitInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="키 (cm)"
                        app:boxBackgroundColor="@color/mypage_warm_white"
                        app:boxStrokeColor="@color/mypage_fern"
                        app:hintTextColor="@color/mypage_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etHeight"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:inputType="numberDecimal"
                            android:minHeight="42dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            android:textColor="@color/mypage_text"
                            android:textColorHint="@color/mypage_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Space
                        android:layout_width="@dimen/fit_space_sm"
                        android:layout_height="1dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/FitInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="몸무게 (kg)"
                        app:boxBackgroundColor="@color/mypage_warm_white"
                        app:boxStrokeColor="@color/mypage_fern"
                        app:hintTextColor="@color/mypage_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etWeight"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:inputType="numberDecimal"
                            android:minHeight="42dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            android:textColor="@color/mypage_text"
                            android:textColorHint="@color/mypage_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/FitInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="주당 운동 횟수"
                        app:boxBackgroundColor="@color/mypage_warm_white"
                        app:boxStrokeColor="@color/mypage_fern"
                        app:hintTextColor="@color/mypage_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etActivityLevel"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:inputType="number"
                            android:minHeight="42dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            android:textColor="@color/mypage_text"
                            android:textColorHint="@color/mypage_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Space
                        android:layout_width="@dimen/fit_space_sm"
                        android:layout_height="1dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/FitInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="목적"
                        app:boxBackgroundColor="@color/mypage_warm_white"
                        app:boxStrokeColor="@color/mypage_fern"
                        app:endIconMode="dropdown_menu"
                        app:hintTextColor="@color/mypage_text_secondary">

                        <AutoCompleteTextView
                            android:id="@+id/actPurpose"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:inputType="none"
                            android:minHeight="42dp"
                            android:paddingStart="@dimen/fit_space_md"
                            android:paddingTop="0dp"
                            android:paddingEnd="@dimen/fit_space_md"
                            android:paddingBottom="0dp"
                            android:singleLine="true"
                            android:textColor="@color/mypage_text"
                            android:textColorHint="@color/mypage_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <View
                    style="@style/FitDivider.Subtle"
                    android:layout_marginTop="@dimen/fit_space_lg"
                    android:layout_marginBottom="@dimen/fit_space_lg" />

                <TextView
                    style="@style/FitText.PrimaryBold16"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="알러지"
                    android:textColor="@color/mypage_text" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fit_space_xs"
                    android:text="자주 입력되는 알러지는 선택하고, 목록에 없으면 직접 추가하세요."
                    android:textColor="@color/mypage_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupAllergy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:chipSpacingHorizontal="6dp"
                    app:chipSpacingVertical="4dp"
                    app:singleLine="false"
                    app:singleSelection="false" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/FitInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:hint="직접 입력"
                        app:boxBackgroundColor="@color/mypage_warm_white"
                        app:boxStrokeColor="@color/mypage_fern"
                        app:hintTextColor="@color/mypage_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCustomAllergy"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:imeOptions="actionDone"
                            android:inputType="text"
                            android:minHeight="48dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            android:singleLine="true"
                            android:textColor="@color/mypage_text"
                            android:textColorHint="@color/mypage_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddCustomAllergy"
                        style="@style/FitCompactButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginStart="@dimen/fit_space_sm"
                        android:layout_marginTop="0dp"
                        android:backgroundTint="@color/mypage_fern"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="48dp"
                        android:minWidth="72dp"
                        android:text="추가"
                        android:textColor="@color/white"
                        app:cornerRadius="6dp" />
                </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/FitPrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/fit_space_xl"
            android:backgroundTint="@color/mypage_fern"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="48dp"
            android:text="저장하기"
            android:textColor="@color/white"
            app:cornerRadius="6dp"
            app:icon="@drawable/ic_save_line"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconTint="@color/white" />
    </LinearLayout>
</ScrollView>
