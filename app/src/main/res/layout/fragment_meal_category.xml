<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mypage_background">

    <LinearLayout
        android:id="@+id/layoutCategoryHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/fit_space_xl"
        android:paddingTop="@dimen/fit_space_lg"
        android:paddingBottom="@dimen/fit_space_md"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="뒤로 가기"
            android:focusable="true"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/mypage_fern"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/tvCategoryTitle"
            style="@style/FitText.PrimaryBold24"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_sm"
            android:text="다이어트" />

        <TextView
            android:id="@+id/tvCategoryDescription"
            style="@style/FitText.Secondary14"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_sm"
            android:text="목적에 맞는 식단을 확인해보세요." />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategoryMeals"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/fit_space_xl"
        android:paddingTop="@dimen/fit_space_sm"
        android:paddingBottom="@dimen/fit_space_2xl"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutCategoryHeader" />

    <ProgressBar
        android:id="@+id/progressCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutCategoryHeader" />

    <LinearLayout
        android:id="@+id/layoutCategoryEmpty"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/fit_space_2xl"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutCategoryHeader">

        <TextView
            style="@style/FitText.PrimaryBold17"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="해당 카테고리의 식단이 없어요." />

        <TextView
            style="@style/FitText.Secondary13"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_sm"
            android:text="다른 카테고리의 식단도 확인해보세요." />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
