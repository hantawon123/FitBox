<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_my_page_screen"
    tools:context=".fragment.ChatFragment">

    <LinearLayout
        android:id="@+id/layoutChatHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_my_page_header"
        android:elevation="3dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/fit_space_md"
        android:paddingEnd="@dimen/fit_space_md"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_my_page_avatar">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ai"
                app:tint="@color/mypage_fern" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/fit_space_md"
            android:layout_weight="1"
            android:text="AI 맞춤 식단 상담소"
            android:textColor="@color/mypage_text"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingTop="@dimen/fit_space_md"
        android:paddingBottom="@dimen/fit_space_md"
        app:layout_constraintBottom_toTopOf="@id/layoutInput"
        app:layout_constraintTop_toBottomOf="@id/layoutChatHeader" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCompleteRegistration"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginBottom="@dimen/fit_space_md"
        android:backgroundTint="@color/mypage_fern"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minHeight="44dp"
        android:paddingStart="@dimen/fit_space_lg"
        android:paddingEnd="@dimen/fit_space_lg"
        android:text="목적 선택하고 가입 완료하기"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:visibility="gone"
        app:cornerRadius="6dp"
        app:layout_constraintBottom_toTopOf="@id/layoutInput"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_input_panel"
        android:elevation="6dp"
        android:gravity="bottom"
        android:orientation="horizontal"
        android:paddingStart="@dimen/fit_space_md"
        android:paddingEnd="@dimen/fit_space_md"
        android:paddingTop="@dimen/fit_space_md"
        android:paddingBottom="@dimen/fit_space_md"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/FitInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:boxBackgroundColor="@color/mypage_warm_white"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            app:boxStrokeColor="@color/mypage_fern"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="질문을 입력하세요..."
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:minHeight="44dp"
                android:paddingTop="@dimen/fit_space_sm"
                android:paddingBottom="@dimen/fit_space_sm"
                android:textColor="@color/mypage_text"
                android:textColorHint="@color/mypage_text_secondary"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            android:layout_width="52dp"
            android:layout_height="44dp"
            android:layout_marginStart="@dimen/fit_space_sm"
            android:backgroundTint="@color/mypage_fern"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="44dp"
            android:text=""
            app:cornerRadius="6dp"
            app:icon="@drawable/ic_send_line"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/white" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutSummaryLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/mypage_honey" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_md"
            android:text="대화를 분석하여 취향을 저장 중입니다... ⏳"
            android:textColor="@color/mypage_warm_white"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
