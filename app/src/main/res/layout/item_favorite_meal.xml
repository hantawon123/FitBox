<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/MypageOutlinedCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/fit_space_md">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/fit_space_lg">

        <TextView
            android:id="@+id/tvFavoriteType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/mypage_fennel"
            android:paddingHorizontal="9dp"
            android:paddingVertical="@dimen/fit_space_xs"
            android:text="AI 추천 식단"
            android:textColor="@color/mypage_primary_dark"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFavoriteName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_md"
            android:text="AI 추천 맞춤 식단"
            style="@style/FitText.PrimaryBold18" />

        <TextView
            android:id="@+id/tvFavoriteNutrition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:lineSpacingExtra="3dp"
            android:text="456.5kcal · 탄수화물 43.6g (38%) · 단백질 53.3g (47%)"
            style="@style/FitText.Secondary13" />

        <TextView
            android:id="@+id/tvFavoriteIngredients"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_sm"
            android:lineSpacingExtra="4dp"
            android:text="• 현미밥 100g\n• 닭가슴살 150g"
            style="@style/FitText.Secondary13"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvFavoritePrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="8,800원"
                style="@style/FitText.PrimaryDarkBold15" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoveFavorite"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="삭제"
                android:textColor="@color/mypage_fern" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddFavoriteToCart"
                style="@style/MypagePrimaryButtonCompact"
                android:layout_width="84dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:text="담기" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
