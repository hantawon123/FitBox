<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_my_page_screen">

    <TextView
        android:id="@+id/tvCartTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/fit_space_md"
        android:layout_marginTop="@dimen/fit_space_2xl"
        android:layout_marginEnd="@dimen/fit_space_md"
        android:text="장바구니"
        android:textColor="@color/mypage_text"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layoutEmptyCart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvCartTitle"
        app:layout_constraintBottom_toTopOf="@id/layoutCartBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:alpha="0.7"
            android:contentDescription="빈 장바구니"
            android:src="@drawable/cart"
            app:tint="@color/mypage_fern" />

        <TextView
            android:id="@+id/tvEmptyCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_lg"
            android:text="장바구니가 비어 있어요"
            android:textColor="@color/mypage_text"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="마음에 드는 식단을 담아보세요."
            android:textColor="@color/mypage_text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEmptyCartShop"
            style="@style/FitSecondaryButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="@android:color/transparent"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="44dp"
            android:text="식단 둘러보기"
            android:textColor="@color/mypage_fern"
            app:cornerRadius="6dp"
            app:strokeColor="@color/mypage_fern" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCartItems"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/fit_space_md"
        android:layout_marginTop="@dimen/fit_space_md"
        android:layout_marginEnd="@dimen/fit_space_md"
        android:layout_marginBottom="@dimen/fit_space_md"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/tvCartTitle"
        app:layout_constraintBottom_toTopOf="@id/layoutCartBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layoutCartBottom"
        android:layout_width="0dp"
        android:layout_height="84dp"
        android:background="@drawable/bg_chat_input_panel"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/fit_space_md"
        android:paddingEnd="@dimen/fit_space_md"
        android:paddingBottom="@dimen/fit_space_sm"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="총 결제 금액"
                android:textColor="@color/mypage_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvCartTotalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0원"
                android:textColor="@color/mypage_fern"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCartOrder"
            style="@style/FitPrimaryButton"
            android:layout_width="132dp"
            android:layout_height="48dp"
            android:backgroundTint="@color/mypage_fern"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="48dp"
            android:text="주문하기"
            android:textColor="@color/white"
            android:textSize="15sp"
            app:cornerRadius="6dp"
            app:icon="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
