<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mypage_background"
    android:orientation="vertical"
    android:padding="@dimen/fit_space_xl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="뒤로 가기"
            android:focusable="true"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/mypage_fern"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/tvNotificationScreenTitle"
            style="@style/FitText.PrimaryBold22"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="알림" />

        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutNotificationEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/fit_space_2xl">

        <ImageView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:contentDescription="알림 없음"
            android:src="@drawable/notifications"
            app:tint="@color/mypage_text_secondary" />

        <TextView
            style="@style/FitText.PrimaryBold17"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_lg"
            android:text="아직 도착한 알림이 없어요." />

        <TextView
            style="@style/FitText.Secondary13"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_sm"
            android:gravity="center"
            android:text="주문 및 구독 알림이 도착하면 이곳에서 확인할 수 있어요." />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNotifications"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="@dimen/fit_space_lg"
        android:paddingBottom="@dimen/fit_space_2xl"
        android:visibility="gone" />

</LinearLayout>
