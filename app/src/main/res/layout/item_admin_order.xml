<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/MypageOutlinedCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/fit_space_md">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/fit_space_lg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvOrderNumber"
                style="@style/FitText.PrimaryBold17"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="주문 #1001" />

            <TextView
                android:id="@+id/tvOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/mypage_fennel"
                android:paddingHorizontal="@dimen/fit_space_sm"
                android:paddingVertical="@dimen/fit_space_xs"
                android:text="신규 주문"
                android:textColor="@color/mypage_primary_dark"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvOrderMeal"
            style="@style/FitText.PrimaryBold15"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_md"
            android:text="고단백 닭가슴살 도시락 · 1개" />

        <TextView
            android:id="@+id/tvOrderCustomer"
            style="@style/FitText.Secondary13"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_sm"
            android:text="고객 김*준" />

        <TextView
            android:id="@+id/tvPickupInfo"
            style="@style/FitText.Secondary13"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_xs"
            android:text="매장 픽업 · 핏박스 강남점" />

        <TextView
            android:id="@+id/tvReceiveDate"
            style="@style/FitText.Secondary13"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_xs"
            android:text="픽업 예정일 · 2026-06-23" />

        <TextView
            android:id="@+id/tvLastPush"
            style="@style/FitText.Secondary12"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_sm"
            android:text="최근 알림: 없음"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminAction"
            style="@style/MypagePrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/fit_space_lg"
            android:text="주문 받기" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
