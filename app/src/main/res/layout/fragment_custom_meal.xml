<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mypage_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/fit_space_xl"
        android:paddingTop="@dimen/fit_space_xl"
        android:paddingEnd="@dimen/fit_space_xl"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/tvCustomTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="현재 영양 밸런스"
            style="@style/FitText.PrimaryBold24" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etCustomMealName"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:hint="식단 이름"
                android:background="@drawable/bg_subscription_address_input"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:inputType="text"
                android:maxLines="1"
                android:minHeight="42dp"
                android:paddingHorizontal="12dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:textColor="@color/mypage_text"
                android:textColorHint="@color/mypage_text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDefaultMealName"
                style="@style/MypageSecondaryButton"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="@dimen/fit_space_sm"
                android:minHeight="42dp"
                android:minWidth="0dp"
                android:paddingHorizontal="16dp"
                android:text="기본값"
                android:textSize="13sp"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardNutritionSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSelectedIngredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="아직 선택된 재료가 없습니다"
                    android:textColor="@color/mypage_primary_dark"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTotalNutrition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0kcal · 탄수화물 0g · 단백질 0g · 지방 0g"
                    style="@style/FitText.Secondary13" />

                <TextView
                    android:id="@+id/tvTotalPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0원"
                    style="@style/FitText.PrimaryDarkBold20" />

        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:columnCount="2"
            android:rowCount="2">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCarbohydrate"
                style="@style/FitChoiceCard">

                <LinearLayout
                    style="@style/FitChoiceCardContent">

                    <ImageView
                        android:id="@+id/ivCarbohydrateImage"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="2"
                        android:background="@android:color/white"
                        android:scaleType="centerCrop"
                        android:src="@drawable/logo_full_background_remove"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="10dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="탄수화물"
                            style="@style/FitText.PrimaryBold14" />

                        <TextView
                            android:id="@+id/tvCarbohydrateSelected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:maxLines="2"
                            android:text="선택 안 됨"
                            style="@style/FitText.Secondary12"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProtein"
                style="@style/FitChoiceCard">

                <LinearLayout
                    style="@style/FitChoiceCardContent">

                    <ImageView
                        android:id="@+id/ivProteinImage"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="2"
                        android:background="@android:color/white"
                        android:scaleType="centerCrop"
                        android:src="@drawable/logo_full_background_remove"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="10dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="단백질"
                            style="@style/FitText.PrimaryBold14" />

                        <TextView
                            android:id="@+id/tvProteinSelected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:maxLines="2"
                            android:text="선택 안 됨"
                            style="@style/FitText.Secondary12"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVegetable"
                style="@style/FitChoiceCard">

                <LinearLayout
                    style="@style/FitChoiceCardContent">

                    <ImageView
                        android:id="@+id/ivVegetableImage"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="2"
                        android:background="@android:color/white"
                        android:scaleType="centerCrop"
                        android:src="@drawable/logo_full_background_remove"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="10dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="채소"
                            style="@style/FitText.PrimaryBold14" />

                        <TextView
                            android:id="@+id/tvVegetableSelected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:maxLines="2"
                            android:text="선택 안 됨"
                            style="@style/FitText.Secondary12"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSauce"
                style="@style/FitChoiceCard">

                <LinearLayout
                    style="@style/FitChoiceCardContent">

                    <ImageView
                        android:id="@+id/ivSauceImage"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="2"
                        android:background="@android:color/white"
                        android:scaleType="centerCrop"
                        android:src="@drawable/logo_full_background_remove"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="10dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="소스"
                            style="@style/FitText.PrimaryBold14" />

                        <TextView
                            android:id="@+id/tvSauceSelected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:maxLines="2"
                            android:text="선택 안 됨"
                            style="@style/FitText.Secondary12"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCustomComplete"
            style="@style/MypagePrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="22dp"
            android:text="커스터마이징 완료" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/fit_space_sm"
            android:gravity="center"
            android:text="카테고리는 자유롭게 선택할 수 있으며, 재료 합계 6,000원 이상부터 주문할 수 있어요."
            style="@style/FitText.Secondary12" />

    </LinearLayout>

</ScrollView>
