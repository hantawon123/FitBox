<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Legacy theme values are preserved in UI_LEGACY_REFERENCE.md. -->
        <item name="colorPrimary">@color/fit_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/fit_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/fit_on_primary_container</item>
        <item name="colorSecondary">@color/fit_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/fit_surface</item>
        <item name="colorSurfaceVariant">@color/fit_surface_variant</item>
        <item name="colorOnSurface">@color/fit_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/fit_text_secondary</item>
        <item name="colorOutline">@color/fit_outline</item>
        <item name="colorOutlineVariant">@color/fit_outline</item>
        <item name="colorError">@color/fit_error</item>
        <item name="android:colorBackground">@color/fit_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/fit_background</item>
        <item name="android:navigationBarColor">@color/mypage_surface</item>
        <item name="materialButtonStyle">@style/FitPrimaryButton</item>
        <item name="materialCardViewStyle">@style/FitCard</item>
    </style>

    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication" />
</resources>
