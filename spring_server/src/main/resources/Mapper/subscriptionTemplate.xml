<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ssafy.fitbox.mapper.SubscriptionTemplateMapper">

    <resultMap id="subscriptionTemplateMap" type="com.ssafy.fitbox.dto.SubscriptionTemplate">
        <id property="id" column="id"/>
        <result property="subscriptionGroupId" column="subscription_group_id"/>
        <result property="weekOfMonth" column="week_of_month"/>
        <result property="dayOfWeek" column="day_of_week"/>
        <result property="mealId" column="meal_id"/>
        <result property="quantity" column="quantity"/>
    </resultMap>

    <resultMap id="subscriptionTemplateResponseMap"
               type="com.ssafy.fitbox.dto.response.SubscriptionTemplateResponse">
        <id property="templateId" column="template_id"/>
        <result property="weekOfMonth" column="week_of_month"/>
        <result property="dayOfWeek" column="day_of_week"/>
        <result property="dayOfWeekText" column="day_of_week_text"/>
        <result property="mealId" column="meal_id"/>
        <result property="mealName" column="meal_name"/>
        <result property="mealPrice" column="meal_price"/>
        <result property="quantity" column="quantity"/>
    </resultMap>

    <insert id="insert"
            parameterType="com.ssafy.fitbox.dto.SubscriptionTemplate"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO subscription_template_table (
            subscription_group_id,
            week_of_month,
            day_of_week,
            meal_id,
            quantity
        )
        VALUES (
            #{subscriptionGroupId},
            #{weekOfMonth},
            #{dayOfWeek},
            #{mealId},
            #{quantity}
        )
    </insert>

    <select id="selectBySubscriptionGroupId" resultMap="subscriptionTemplateMap">
        SELECT
            id,
            subscription_group_id,
            week_of_month,
            day_of_week,
            meal_id,
            quantity
        FROM subscription_template_table
        WHERE subscription_group_id = #{subscriptionGroupId}
        ORDER BY week_of_month, day_of_week, id
    </select>

    <select id="findTemplateResponsesBySubscriptionGroupId"
            resultMap="subscriptionTemplateResponseMap">
        SELECT
            st.id AS template_id,
            st.week_of_month,
            st.day_of_week,
            CASE st.day_of_week
                WHEN 1 THEN '일요일'
                WHEN 2 THEN '월요일'
                WHEN 3 THEN '화요일'
                WHEN 4 THEN '수요일'
                WHEN 5 THEN '목요일'
                WHEN 6 THEN '금요일'
                WHEN 7 THEN '토요일'
                ELSE '알 수 없음'
            END AS day_of_week_text,
            st.meal_id,
            m.name AS meal_name,
            m.price AS meal_price,
            st.quantity
        FROM subscription_template_table st
        JOIN meal_table m
            ON st.meal_id = m.id
        WHERE st.subscription_group_id = #{subscriptionGroupId}
        ORDER BY st.week_of_month, st.day_of_week, st.id
    </select>

</mapper>
