<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ssafy.fitbox.mapper.MealIngredientMapper">

    <resultMap id="mealIngredientMap" type="MealIngredient">
        <id property="id" column="id"/>
        <result property="mealId" column="meal_id"/>
        <result property="ingredientId" column="ingredient_id"/>
        <result property="amount" column="amount"/>
    </resultMap>

    <select id="selectAll" resultMap="mealIngredientMap">
        SELECT id, meal_id, ingredient_id, amount
        FROM meal_ingredient_table
        ORDER BY id DESC
    </select>

    <select id="selectById" parameterType="int" resultMap="mealIngredientMap">
        SELECT id, meal_id, ingredient_id, amount
        FROM meal_ingredient_table
        WHERE id = #{id}
    </select>

    <select id="selectByMealId" parameterType="int" resultMap="mealIngredientMap">
        SELECT id, meal_id, ingredient_id, amount
        FROM meal_ingredient_table
        WHERE meal_id = #{mealId}
        ORDER BY id
    </select>

    <insert id="insert" parameterType="MealIngredient" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO meal_ingredient_table (
            meal_id,
            ingredient_id,
            amount
        )
        VALUES (
            #{mealId},
            #{ingredientId},
            #{amount}
        )
    </insert>

    <delete id="delete" parameterType="int">
        DELETE FROM meal_ingredient_table
        WHERE id = #{id}
    </delete>

    <delete id="deleteByMealId" parameterType="int">
        DELETE FROM meal_ingredient_table
        WHERE meal_id = #{mealId}
    </delete>

</mapper>